# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=dev-key-change-me

# PostgreSQL Connection
DATABASE_URL=postgresql://user:password@localhost:5432/insightradar

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here

# Feishu (Lark) Configuration
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token_here
FEISHU_BITABLE_TABLE_ID=your_table_id_here

# Social Media Data Collection
TAVILY_API_KEY=your_tavily_api_key_here
APIFY_API_KEY=your_apify_api_key_here
SOCIAL_KEYWORDS=PostHog,Mixpanel,Amplitude,神策数据,product analytics
SOCIAL_COLLECTION_MODE=fast  # fast (Tavily) or deep (Apify)

# OpenAI Compatible API Configuration (for LLM Analysis)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TIMEOUT=30
OPENAI_MAX_TOKENS=1000

# Task Scheduler Configuration
SCHEDULER_COLLECTION_HOUR=2  # Hour of day (0-23) for daily collection
SCHEDULER_COLLECTION_MINUTE=0  # Minute of hour (0-59)
